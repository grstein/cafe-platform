# ──────────────────────────────────────────────────────────────
# cafe-platform environment variables
#
# Copy this file to .env and adjust. Never commit .env.
# ──────────────────────────────────────────────────────────────

# Order / referral ID prefixes
ORDER_PREFIX=
REFERRAL_CODE_PREFIX=REF-

# RabbitMQ
RABBITMQ_USER=evolution
RABBITMQ_PASSWORD=change-me
RABBITMQ_URI=amqp://evolution:change-me@rabbitmq:5672/evolution

# PostgreSQL
POSTGRES_DB=cafe
POSTGRES_USER=cafe
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://cafe:change-me@database:5432/cafe

# LLM provider (OpenRouter)
OPENROUTER_API_KEY=

# PIX (leave blank if pix.enabled=false in pi-config/config.json)
PIX_KEY=
PIX_NAME=
PIX_CITY=

# Bot WhatsApp number (digits only, include country + area code)
BOT_PHONE=

# Paths (inside container — only change if docker-compose mounts change)
LOG_DIR=/logs
DATA_DIR=/data
CONFIG_DIR=/config/pi
