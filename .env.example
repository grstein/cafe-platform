# ──────────────────────────────────────────────────────────────
# cafe-platform environment variables
#
# For local development, copy this file to .env and adjust values.
# Never commit .env.
# ──────────────────────────────────────────────────────────────

# Tenant selection — must match a directory name under TENANTS_DIR.
# For the quickstart, use the bundled demo tenant:
TENANT_ID=demo-tenant

# Order / referral ID prefixes (shown in messages; alphanumeric only for
# the PIX identifier — non-alphanumeric chars are stripped there).
ORDER_PREFIX=
REFERRAL_CODE_PREFIX=REF-

# RabbitMQ
RABBITMQ_USER=evolution
RABBITMQ_PASSWORD=change-me
RABBITMQ_URI=amqp://evolution:change-me@rabbitmq:5672/evolution

# LLM provider (OpenRouter by default)
OPENROUTER_API_KEY=

# PIX (leave blank if pix.enabled=false in tenant.json)
PIX_KEY=
PIX_NAME=
PIX_CITY=

# Bot WhatsApp number (digits only, include country + area code)
BOT_PHONE=

# Paths (inside container — only change if docker-compose mounts change)
LOG_DIR=/logs
DATA_DIR=/data
TENANTS_DIR=/tenants
CONFIG_DIR=/config/pi
WORKSPACE=/tenants
