{
  "name": "cafe-platform",
  "version": "8.0.0",
  "type": "module",
  "description": "WhatsApp agent platform with RabbitMQ pipeline and Pi Agent SDK",
  "scripts": {
    "test": "node --test --test-concurrency=1 --import=./tests/setup.mjs \"tests/unit/**/*.test.mjs\" \"tests/integration/**/*.test.mjs\"",
    "test:unit": "node --test --test-concurrency=1 --import=./tests/setup.mjs \"tests/unit/**/*.test.mjs\"",
    "test:integration": "node --test --test-concurrency=1 --import=./tests/setup.mjs \"tests/integration/**/*.test.mjs\"",
    "sim:load": "node scripts/sim/sim-load.mjs",
    "sim:rapid": "node scripts/sim/sim-rapid-fire.mjs",
    "sim:resilience": "node scripts/sim/sim-resilience.mjs",
    "sim:probe": "node scripts/sim/probe-queues.mjs",
    "sim:bench": "node scripts/sim/bench-report.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@sinclair/typebox": "^0.34.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "amqplib": "^1.0.3",
    "gpix": "^1.1.2",
    "postgres": "^3.4.9",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^9.0.0"
  }
}
